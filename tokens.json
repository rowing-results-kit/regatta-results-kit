{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "_meta": {
    "project": "regatta-results-kit",
    "version": "1.0.0",
    "inherits": "ryuiyamada-design-system",
    "updated": "2026-06-12",
    "note": "グローバルDSから差分のみ上書き。ここにないトークンはグローバルDS準拠"
  },

  "color": {
    "_comment": "水面の深い青緑をプライマリ。紫・水色グラデ系は禁止。審判旗の赤をアクセント1点のみ",
    "primary":     { "value": "#0E4D5C", "type": "color", "comment": "水面深い青緑。CTAボタン・リンク・インタラクティブ要素" },
    "primary-600": { "value": "#0B3D4A", "type": "color", "comment": "primary hover/pressed" },
    "primary-100": { "value": "#E0F2F7", "type": "color", "comment": "primary淡色。背景ハイライト・badge" },
    "accent":      { "value": "#C0392B", "type": "color", "comment": "審判旗の赤。1画面1箇所のみ。勝者・重要アラートのみ使用" },
    "accent-bg":   { "value": "#FDEDEC", "type": "color", "comment": "accent淡色。背景のみ" },
    "lane-1":      { "value": "#0E4D5C", "type": "color", "comment": "レーン1 = primary" },
    "lane-2":      { "value": "#196B7A", "type": "color", "comment": "レーン2" },
    "lane-3":      { "value": "#1F8A9A", "type": "color", "comment": "レーン3" },
    "lane-4":      { "value": "#26A9BB", "type": "color", "comment": "レーン4" },
    "lane-5":      { "value": "#2EC7DC", "type": "color", "comment": "レーン5（明るい水面色）" },
    "lane-6":      { "value": "#7AD8E4", "type": "color", "comment": "レーン6（最も明るい）" },
    "text":        { "value": "#1A1A2E", "type": "color", "comment": "本文。グローバルDS準拠" },
    "muted":       { "value": "#6B7280", "type": "color", "comment": "補足・ラベル。グローバルDS準拠" },
    "border":      { "value": "#DDE4E8", "type": "color", "comment": "罫線。レーン罫線にも使用" },
    "bg":          { "value": "#FFFFFF", "type": "color" },
    "bg-sub":      { "value": "#F5F7F8", "type": "color", "comment": "オフホワイト。生成りトーン" },
    "success":     { "value": "#16A34A", "type": "color" },
    "success-bg":  { "value": "#DCFCE7", "type": "color" },
    "warning":     { "value": "#D97706", "type": "color" },
    "error":       { "value": "#DC2626", "type": "color" },
    "_forbidden_colors": {
      "comment": "これらの系統は使用禁止",
      "purple-family": "#7C3AED / #8B5CF6 / #A855F7 — 汎用グラデーション系紫",
      "blue-gradient-pair": "#60A5FA + #A78BFA — AIサービス典型ペア禁止",
      "cyan-bright": "#22D3EE 系の明るい水色単体使用禁止（lane-6まで）"
    }
  },

  "typography": {
    "_comment": "グローバルDS継承。数値表示にtabular-nums必須",
    "font-family":  { "value": "\"Noto Sans JP\", sans-serif", "type": "fontFamily" },
    "font-feature": { "value": "'palt' 1, 'kern' 1, 'tnum' 1", "type": "string", "comment": "数値列・タイム表示で必ずtnum有効化" },
    "display":      { "value": { "fontSize": "clamp(2rem, 5.5vw, 3.25rem)", "fontWeight": 700, "letterSpacing": "-0.025em", "lineHeight": 1.15 }, "type": "typography" },
    "h1":           { "value": { "fontSize": "clamp(1.625rem, 4vw, 2.25rem)", "fontWeight": 700, "letterSpacing": "-0.02em", "lineHeight": 1.25 }, "type": "typography" },
    "h2":           { "value": { "fontSize": "clamp(1.25rem, 3vw, 1.625rem)", "fontWeight": 700, "letterSpacing": "-0.01em", "lineHeight": 1.35 }, "type": "typography" },
    "h3":           { "value": { "fontSize": "clamp(1rem, 2vw, 1.125rem)", "fontWeight": 700, "lineHeight": 1.5 }, "type": "typography" },
    "body":         { "value": { "fontSize": "clamp(0.9375rem, 1.4vw, 1rem)", "fontWeight": 500, "lineHeight": 1.85 }, "type": "typography" },
    "small":        { "value": { "fontSize": "clamp(0.75rem, 1.2vw, 0.8125rem)", "fontWeight": 500 }, "type": "typography" },
    "eyebrow":      { "value": { "fontSize": "0.6875rem", "fontWeight": 700, "letterSpacing": "0.2em", "textTransform": "uppercase" }, "type": "typography" },
    "numeric":      { "value": { "fontVariantNumeric": "tabular-nums", "fontWeight": 700, "letterSpacing": "-0.02em" }, "type": "typography", "comment": "タイム・順位・ステップ数など数値専用" }
  },

  "spacing": {
    "_comment": "8pxグリッド固定",
    "1":  { "value": "0.5rem",   "type": "spacing", "px": 8 },
    "2":  { "value": "1rem",     "type": "spacing", "px": 16 },
    "3":  { "value": "1.5rem",   "type": "spacing", "px": 24 },
    "4":  { "value": "2rem",     "type": "spacing", "px": 32 },
    "5":  { "value": "3rem",     "type": "spacing", "px": 48 },
    "6":  { "value": "4rem",     "type": "spacing", "px": 64 },
    "7":  { "value": "5rem",     "type": "spacing", "px": 80 },
    "8":  { "value": "6rem",     "type": "spacing", "px": 96 }
  },

  "layout": {
    "max-width":    { "value": "min(100%, 1040px)", "type": "dimension" },
    "padding-inline": { "value": "clamp(1rem, 5vw, 3rem)", "type": "dimension" },
    "section-block": { "value": "clamp(4rem, 10vw, 7rem)", "type": "dimension" }
  },

  "radius": {
    "_comment": "小さめ2段階のみ。radius-full（9999px）はバッジ限定",
    "sm":   { "value": "2px",    "type": "borderRadius", "comment": "テーブルセル・罫線コーナー" },
    "md":   { "value": "4px",    "type": "borderRadius", "comment": "カード・パネル・モーダル" },
    "full": { "value": "9999px", "type": "borderRadius", "comment": "バッジ・ステータスチップのみ。ボタンに使用禁止" }
  },

  "border": {
    "lane":  { "value": "2px solid var(--color-border)", "type": "border", "comment": "レーン水平罫線" },
    "buoy":  { "value": "1px solid var(--color-primary-100)", "type": "border", "comment": "ブイ点列のベースライン" },
    "focus": { "value": "2px solid var(--color-primary)", "type": "border", "comment": "focus-visibleリング必須" }
  },

  "shadow": {
    "_comment": "影は最小限。box-shadow多用禁止",
    "subtle": { "value": "0 1px 2px rgba(0,0,0,0.06)", "type": "shadow", "comment": "唯一の許可影。カードに必要な時のみ" }
  },

  "motion": {
    "duration-fast":   { "value": "100ms", "type": "duration" },
    "duration-normal": { "value": "200ms", "type": "duration" },
    "easing-default":  { "value": "cubic-bezier(0.4, 0, 0.2, 1)", "type": "cubicBezier" }
  },

  "lane-motif": {
    "_comment": "レーンモチーフのトークン定義",
    "line-height":  { "value": "1px", "type": "dimension", "comment": "水平レーン罫線の太さ" },
    "buoy-size":    { "value": "6px", "type": "dimension", "comment": "ブイ点の直径" },
    "buoy-gap":     { "value": "8px", "type": "dimension", "comment": "ブイ点の間隔" },
    "progress-height": { "value": "4px", "type": "dimension", "comment": "進行バー（レーン表現）の高さ" }
  }
}
