  "conventions": {
    "bn": "boat number / lane position in the target race",
    "source": "PDF source expression such as 1.HT, 1.1.H, 2.3.S",
    "status_order": [
      "finish",
      "dnf",
      "dq",
      "dns",
      "unknown"
    ],
    "status_policy": "許可リスト（SPEC §6.1）。finish 以外（EXC・未知コード・綴り誤り = unknown を含む）は進出対象外。status_order は非完漕どうしの決定的な並び順を与えるのみで、進出可否には関与しない",
    "tie_policy": "keep tied crews in the same tie_group and preserve deterministic input_order inside that group until an official tie-break is supplied",
    "skip_if": "the target race is not created when it has only one assigned crew"
  },
  "test_cases": [
